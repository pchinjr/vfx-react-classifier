{
  "lock": true,
  "nodeModulesDir": "auto",
  "tasks": {
    "fmt:check": "deno fmt --check",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno check src/**/*.ts scripts/**/*.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-run",
    "db:init": "deno run --allow-read --allow-write --allow-env scripts/init_db.ts",
    "ingest": "deno run --allow-read --allow-write --allow-env --allow-run --allow-net src/cli/ingest.ts",
    "ingest:batch": "deno run --allow-read --allow-write --allow-env --allow-run --allow-net src/cli/ingest.ts --batch",
    "spans:build": "deno run --allow-read --allow-write --allow-env src/cli/buildSpans.ts",
    "spans:list": "deno run --allow-read --allow-write --allow-env src/cli/listSpans.ts",
    "spans:candidates": "deno run --allow-read --allow-write --allow-env --allow-net src/cli/listSpanCandidates.ts",
    "spans:label": "deno run --allow-read --allow-write --allow-env src/cli/labelSpan.ts",
    "movies:search": "deno run --allow-read --allow-write --allow-env --allow-net src/cli/searchMovies.ts",
    "resolve:episode": "deno run --allow-read --allow-write --allow-env --allow-net src/cli/resolveEpisode.ts",
    "episode:report": "deno run --allow-read --allow-write --allow-env src/cli/episodeReport.ts",
    "ml:build-dataset": "deno run --allow-read --allow-write --allow-env src/cli/buildMlDataset.ts",
    "ml:features": "deno run --allow-read --allow-write --allow-env src/cli/inspectMlFeatures.ts",
    "ml:train": "deno run --allow-read --allow-write --allow-env src/cli/trainMlReranker.ts",
    "query": "deno run --allow-read --allow-write --allow-env --allow-net src/cli/query.ts",
    "reembed": "deno run --allow-read --allow-write --allow-env --allow-net src/cli/reembed.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2",
    "openai": "npm:openai@^5.12.2",
    "sqlite": "https://deno.land/x/sqlite@v3.9.1/mod.ts"
  },
  "fmt": {
    "semiColons": false,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "compilerOptions": {
    "strict": true
  }
}
